---
import type { LocalImageProps } from "astro:assets";

interface Props {
  src: LocalImageProps["src"] | string;
  caption?: string;
  width?: number | string;
  border?: boolean;
}

const {
  src,
  caption = "",
  width,
  border = true
} = Astro.props;

const imgSrc = typeof src === "string" ? src : src.src;

const imgClass = [
  "zoomable",
  border ? "border" : "",
  "rounded"
].join(" ");
---

<figure class="my-6 flex flex-col items-center gap-2">
  <img
    src={imgSrc}
    alt={caption}
    width={width}
    class={imgClass}
    loading="lazy"
    data-zoomable
  />

  {caption && (
    <figcaption class="text-sm text-slate-500 text-center">
      {caption}
    </figcaption>
  )}
</figure>