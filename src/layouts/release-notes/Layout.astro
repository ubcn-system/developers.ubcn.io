---
import Footer from '../../components/Footer.astro';
const {frontmatter} = Astro.props;
const classList = `mt-4 mb-6 text-xl text-gray`;
---
<div class={classList}>
    <div class="relative">
        <div>
            <img src="https://developers.ubcn.co.kr/assets/banner_1920x700.png" alt="banner" class="rounded"/>
        </div>
        <div class="hidden md:block absolute bottom-0 pl-4 pb-2 text-white text-4xl font-bold text-center">{frontmatter.title} 소식을 안내드립니다.</div>
    </div>
    <h1 id="주요 업데이트 사항">주요 업데이트 사항</h1>
</div>
<div class="mb-20" id="contents">
    <slot/>
</div>
<hr>
<Footer/>
<script>
  import mediumZoom from "medium-zoom";

  let zoom: any;

  const initZoom = () => {
    const targets = document.querySelectorAll("#contents img[data-zoomable]");
    if (!targets.length) return;

    zoom?.detach();

    zoom = mediumZoom(targets, {
      margin: 24,
      background: "rgba(0,0,0,0.9)",
      scrollOffset: 40
    });
  };

  initZoom();
  document.addEventListener("astro:page-load", initZoom);
</script>